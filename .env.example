# Sao chép file này thành ".env" rồi điền giá trị thật.
#   PowerShell:  Copy-Item .env.example .env
#
# Lưu ý: phần EMBEDDING chạy LOCAL & MIỄN PHÍ, không cần key nào.
# Bạn chỉ cần MỘT key cho phần sinh câu trả lời (chọn 1 trong 2 bên dưới).

# === CHỌN NHÀ CUNG CẤP LLM (phần sinh câu trả lời) ===
#   openrouter -> dùng model MIỄN PHÍ qua OpenRouter (mặc định, hợp để test)
#   anthropic  -> dùng Claude (trả phí, chất lượng cao)
LLM_PROVIDER=openrouter

# --- (A) Nếu dùng OpenRouter ---
# 1) Tạo key MIỄN PHÍ tại: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...
# 2) Chọn model miễn phí (slug PHẢI có đuôi ":free").
#    Xem danh sách & lọc "free" tại: https://openrouter.ai/models
#    Vài lựa chọn đa ngôn ngữ (hỗ trợ tiếng Việt) thường có sẵn:
#      meta-llama/llama-3.3-70b-instruct:free
#      deepseek/deepseek-chat-v3-0324:free
#      qwen/qwen-2.5-72b-instruct:free
#    Nếu báo lỗi "model not found", hãy mở trang trên và copy slug đang còn miễn phí.
OPENROUTER_MODEL=qwen/qwen3-32b

# --- (B) Nếu dùng Claude (chỉ cần khi LLM_PROVIDER=anthropic) ---
# Lấy key tại: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx
#   claude-opus-4-8 (mạnh nhất) | claude-sonnet-4-6 (cân bằng) | claude-haiku-4-5 (rẻ/nhanh)
CLAUDE_MODEL=claude-opus-4-8

# === Tham số chung ===
# Số token tối đa cho 1 câu trả lời
MAX_TOKENS=2048

# Model embedding (chạy local, đa ngôn ngữ, hỗ trợ tiếng Việt; KHÔNG cần key).
# Muốn chất lượng cao hơn (chậm hơn): intfloat/multilingual-e5-base
EMBEDDING_MODEL=intfloat/multilingual-e5-small

# Tham số RAG
CHUNK_SIZE=1000      # số ký tự mỗi đoạn (chunk)
CHUNK_OVERLAP=150    # số ký tự gối nhau giữa 2 đoạn liền kề
TOP_K=5              # số đoạn liên quan nhất lấy ra cho mỗi câu hỏi

# === Chế độ RAG ===
# agentic -> vòng lặp tự điều hướng (mặc định)
# basic   -> tìm 1 lần (đơn giản nhất, để so sánh)
# tools   -> tool-calling agent: LLM tự quyết định gọi công cụ tìm kiếm
#            (cần model có hỗ trợ "tools"; nhiều model free trên OpenRouter có)
RAG_MODE=agentic
AGENT_MAX_ITERS=2        # số vòng truy hồi tối đa (giảm còn 1 nếu model free bị giới hạn lượt)
AGENT_MAX_QUERIES=3      # số truy vấn con tối đa khi tách câu hỏi
AGENT_CONTEXT_LIMIT=8    # số đoạn tối đa đưa vào bước tổng hợp câu trả lời
TOOLS_MAX_CALLS=5        # số lượt gọi công cụ tối đa (chế độ tools)

# === Re-ranking (xếp hạng lại kết quả truy hồi) ===
RERANK_ENABLED=true      # đặt false để tắt (nhanh hơn, đỡ tải thêm model)
# Cross-encoder đa ngôn ngữ, nhỏ gọn. Chất lượng cao hơn (nặng hơn): BAAI/bge-reranker-v2-m3
RERANK_MODEL=cross-encoder/mmarco-mMiniLMv2-L12-H384-v1
RERANK_CANDIDATES=20     # số ứng viên lấy ra trước khi xếp hạng lại

# === Nhớ hội thoại ===
HISTORY_TURNS=4          # số lượt hội thoại gần nhất được nhớ
